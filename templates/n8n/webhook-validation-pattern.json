        "conditions": {
          "string": [
            {
              "value1": "={{ $json.requiredField }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      }
    },
    {
      "id": "document-assumptions",
      "name": "Document Intake Assumptions",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [280, 220],
      "parameters": {
        "content": "Document accepted payload shape, owner, failure behavior, and review date."
      }
    }
  ],
  "connections": {
